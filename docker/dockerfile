# Build context is the din repo itself (cloudevent is a published public module now —
# no sibling checkout, no replace). Build from the repo root:
#   docker build -f docker/dockerfile .
FROM golang:1.26 AS build
RUN useradd -u 10001 dimo
WORKDIR /src
# Resolve modules first so the dep layer caches across source changes (cloudevent is
# public — no auth needed to fetch it).
COPY go.mod go.sum ./
RUN go mod download
COPY . ./
# CGO for the embedded DuckDB (duckdb-go ships prebuilt static bindings).
RUN CGO_ENABLED=1 go build -o /din ./cmd/din
# Bake DuckDB extensions into the image so pods never download them.
RUN /din install-duckdb-extensions /duckdb-extensions

# distroless/cc (not static): the DuckDB bindings link libstdc++.
FROM gcr.io/distroless/cc AS final
LABEL maintainer="DIMO <hello@dimo.zone>"
USER nonroot:nonroot
COPY --from=build --chown=nonroot:nonroot /din /
COPY --from=build --chown=nonroot:nonroot /duckdb-extensions /duckdb-extensions
ENV LAKE_EXTENSION_DIR=/duckdb-extensions
ENTRYPOINT ["/din"]
